  "components": {
    "schemas": {
      "CargoCreate": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name"
          },
          "weight_kg": {
            "type": "number",
            "exclusiveMinimum": 0,
            "title": "Weight Kg"
          },
          "size": {
            "$ref": "#/components/schemas/CargoSize"
          }
        },
        "type": "object",
        "required": [
          "name",
          "weight_kg",
          "size"
        ],
        "title": "CargoCreate"
      },
      "CargoOut": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "weight_kg": {
            "type": "number",
            "title": "Weight Kg"
          },
          "size": {
            "$ref": "#/components/schemas/CargoSize"
          },
          "status": {
            "$ref": "#/components/schemas/CargoStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "weight_kg",
          "size",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "CargoOut"
      },
      "CargoSaveItem": {
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name"
          },
          "weight_kg": {
            "type": "number",
            "exclusiveMinimum": 0,
            "title": "Weight Kg"
          },
          "size": {
            "$ref": "#/components/schemas/CargoSize"
          }
        },
        "type": "object",
        "required": [
          "name",
          "weight_kg",
          "size"
        ],
        "title": "CargoSaveItem",
        "description": "Элемент в декларативном PUT cargos: если есть id — существующий\n(поля name/weight/size игнорируются), без id — добавление нового."
      },
      "CargoSize": {
        "type": "string",
        "enum": [
          "s",
          "m",
          "l"
        ],
        "title": "CargoSize"
      },
      "CargoStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_transit",
          "delivered",
          "cancelled"
        ],
        "title": "CargoStatus"
      },
      "CargosSaveRequest": {
        "properties": {
          "cargos": {
            "items": {
              "$ref": "#/components/schemas/CargoSaveItem"
            },
            "type": "array",
            "minItems": 1,
            "title": "Cargos"
          }
        },
        "type": "object",
        "required": [
          "cargos"
        ],
        "title": "CargosSaveRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "OrderCreate": {
        "properties": {
          "direction": {
            "$ref": "#/components/schemas/OrderDirection"
          },
          "cargos": {
            "items": {
              "$ref": "#/components/schemas/CargoCreate"
            },
            "type": "array",
            "minItems": 1,
            "title": "Cargos"
          }
        },
        "type": "object",
        "required": [
          "direction",
          "cargos"
        ],
        "title": "OrderCreate"
      },
      "OrderDirection": {
        "type": "string",
        "enum": [
          "to_orbit",
          "to_earth"
        ],
        "title": "OrderDirection"
      },
      "OrderListItem": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "direction": {
            "$ref": "#/components/schemas/OrderDirection"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "direction",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "OrderListItem"
      },
      "OrderOut": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "direction": {
            "$ref": "#/components/schemas/OrderDirection"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "cargos": {
            "items": {
              "$ref": "#/components/schemas/CargoOut"
            },
            "type": "array",
            "title": "Cargos"
          }
        },
        "type": "object",
        "required": [
          "id",
          "direction",
          "status",
          "created_at",
          "updated_at",
          "cargos"
        ],
        "title": "OrderOut"
      },
      "OrderStatus": {
        "type": "string",
        "enum": [
          "created",
          "in_progress",
          "delivered",
          "cancelled"
        ],
        "title": "OrderStatus"
      },
      "Role": {
        "type": "string",
        "enum": [
          "admin",
          "manager",
          "client"
        ],
        "title": "Role"
      },
      "Token": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "role"
        ],
        "title": "Token"
      },
      "UserCreate": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "maxLength": 128,
            "minLength": 8,
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "UserCreate"
      },
      "UserOut": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "email",
          "role",
          "created_at"
        ],
        "title": "UserOut"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}